        <!-- ______ -->
        <!-- Joints -->
        <!-- ______ -->

        <joint name = "back_swivel_to_chasis" type="fixed">
            <pose>0.292 0.343 -0.211 0 0 0</pose> 
            <parent>chasis</parent>
            <child>back_swivel</child>
            <axis>
                <xyz expressed_in="__model__">0 0 1</xyz>
                <limit>
                    <effort>1e9</effort>
                    <lower>-1e9</lower>
                    <upper>1e9</upper>
                </limit>
                <dynamics>
                    <damping>0.5</damping>
                    <friction>0.1</friction>
                </dynamics>
            </axis>
        </joint>

        <joint name = "back_wheel_to_swivel" type="revolute">
            <pose>0.292 0.343 -0.250 0 0 0</pose> 
            <parent>back_swivel</parent>
            <child>back_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <lower>-1e9</lower>
                    <upper>1e9</upper>
                    <effort>1e12</effort>
                    <velocity>10</velocity>
                </limit>
                <dynamics>
                    <damping>0.5</damping>
                    <friction>0.1</friction>
                </dynamics>
            </axis>
        </joint>

        <joint name = "front_swivel_to_chasis" type="fixed">
            <pose>0.292 0.343 -0.211 0 0 0</pose> 
            <parent>chasis</parent>
            <child>front_swivel</child>
            <axis>
                <xyz expressed_in="__model__">0 0 1</xyz>
                <limit>
                    <effort>1e9</effort>
                    <lower>-1e9</lower>
                    <upper>1e9</upper>
                </limit>
                <dynamics>
                    <damping>0.5</damping>
                    <friction>0.1</friction>
                </dynamics>
            </axis>
        </joint>

        <joint name = "front_wheel_to_swivel" type="revolute">
            <pose>0.292 0.343 -0.250 0 0 0</pose> 
            <parent>front_swivel</parent>
            <child>front_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <effort>1e9</effort>
                    <lower>-1e9</lower>
                    <upper>1e9</upper>
                </limit>
                <dynamics>
                    <damping>0.5</damping>
                    <friction>0.1</friction>
                </dynamics>
            </axis>
        </joint>

        
    
        <!-- ______ -->
        <!-- plugins -->
        <!-- ______ -->
        <plugin filename="gz-sim-joint-controller-system"
        name="gz::sim::systems::JointController">
            <joint_name>back_wheel_to_swivel</joint_name>
            <initial_velocity>1.0</initial_velocity>
        </plugin>

        <plugin filename="gz-sim-joint-controller-system"
        name="gz::sim::systems::JointController">
            <joint_name>front_wheel_to_swivel</joint_name>
            <initial_velocity>-1.0</initial_velocity>
        </plugin>

    </model>
</sdf>