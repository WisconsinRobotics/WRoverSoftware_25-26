<?xml version="1.0" encoding="UTF-8"?>

<sdf version = "1.9">
    <model name = "rover">
        <pose> 1 0 1 0 0 0</pose>
        <include>
            <uri>model://rover/rover_parts/main_body</uri>
        </include>
        <include>
            <name>swerve_right</name>
            <uri>model://rover/rover_parts/right_drive</uri>
        </include>
        <include>
            <name>swerve_left</name>
            <pose>-0.584 0 0 0 0 0</pose>
            <uri>model://rover/rover_parts/right_drive</uri>
        </include>

        <joint name = "main_body_to_right_chasis" type="revolute">
            <parent>main_body::body</parent>
            <child>swerve_right::chasis</child>
            <axis>
                <xyz expressed_in="__model__">0 0 1</xyz>
                <limit>
                    <lower>-1.76769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
            </axis>
        </joint>
        <joint name = "main_body_to_left_chasis" type="revolute">
            <parent>main_body::body</parent>
            <child>swerve_left::chasis</child>
            <axis>
                <xyz expressed_in="__model__">0 0 1</xyz>
                <limit>
                    <lower>-1.76769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
            </axis>
        </joint>
    </model>
</sdf>