<?xml version="1.0"?>

<sdf version = "1.9">
    <model name = "right_drive">
        <!-- _____ -->
        <!-- Links -->
        <!-- _____ -->
        <link name = "left_wheel_swivel">
            <inertial>
                <!-- 21.426 lbs -> -->
                <mass>0.454</mass> 
                <!-- center of mass -> -->
                <pose>0.292 -0.574 -0.165 0 0 0</pose>
                <inertia>
                    <ixx>0.001</ixx>
                    <ixy>0.000006362</ixy>
                    <ixz>-0.0000001859</ixz>
                    <iyy>0.001</iyy>
                    <iyz>-0.00000007771</iyz>
                    <izz>0.0003299</izz>
                </inertia> 
            </inertial>

            <visual name = "visual">
                <geometry>
                    <mesh>
                        <uri>model://meshes/drive/wheel_swivel/right_swerve_wheel_left.stl</uri>
                    </mesh>
                </geometry>
                <material>
                    <ambient>1.0 0.0 0.0 1</ambient>
                    <diffuse>1.0 0.0 0.0 1</diffuse>
                    <specular>0.1 0.1 0.1 1</specular>
                </material>
            </visual>

            <collision name="collision">
                <pose>0.292 -.574 -0.25 -1.5707 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.11</radius>
                        <length>0.2</length>
                    </cylinder>
                </geometry>
            </collision>

            <visual name = "collision_visual">
                <pose>0.292 -.574 -0.25 -1.5707 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.11</radius>
                        <length>0.2</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.0 1.0 0.0 0.6</ambient>
                    <diffuse>0.0 1.0 0.0 0.6</diffuse>
                    <specular>0.1 0.1 0.1 0.6</specular>
                </material>
            </visual>
        </link>
        <link name = "chasis">
            <inertial>
                <!-- Metric pulled from onshape -> -->
                <mass>6.019</mass> 
                <pose>0.292 -0.115 -0.004 0 0 0 </pose>
                <inertia>
                    <ixx>0.919</ixx>
                    <ixy>-0.00008998</ixy>
                    <ixz>0.000008095</ixz>
                    <iyy>0.024</iyy>
                    <iyz>-0.00001027</iyz>
                    <izz>0.898</izz>
                </inertia> 
            </inertial>
            
            <visual name = "visual">
                <geometry>
                    <mesh>
                        <uri>model://meshes/drive/drive_chasis/right_drive_chasis.stl</uri>
                    </mesh>
                </geometry>
                <material>
                    <ambient>0.0 0.0 1.0 1</ambient>
                    <diffuse>0.0 0.0 1.0 1</diffuse>
                    <specular>0.0 0.0 1.0 1</specular>
                </material>
            </visual>

            <collision name="collision">
                <pose>0.292 -0.115 -0.0125 0 0 0 </pose>
                <geometry>
                    <box>
                        <size>0.044 1.1 0.25</size>
                    </box>
                </geometry>
            </collision>

            <visual name = "collision_visual">
                <pose>0.292 -0.115 -0.0125 0 0 0 </pose>
                <geometry>
                    <box>
                        <size>0.044 1.1 0.25</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.0 1.0 0.0 0.6</ambient>
                    <diffuse>0.0 1.0 0.0 0.6</diffuse>
                    <specular>0.1 0.1 0.1 0.6</specular>
                </material>
            </visual>
        </link>
        <link name = "right_wheel_swivel">
        <inertial>
                <!-- 21.426 lbs -> -->
                <mass>0.227</mass> 
                <!-- center of mass -> -->
                <pose>0.292 0.343 -.211 0 0 0</pose>
                <inertia>
                    <ixx>1.140e-4</ixx>
                    <ixy>5.179e-6</ixy>
                    <ixz>-8.376e-8</ixz>
                    <iyy>8.434e-5</iyy>
                    <iyz>1.855e-8</iyz>
                    <izz>1.776e-4</izz>
                </inertia> 
            </inertial>

            <visual name = "visual">
                <geometry>
                    <mesh>
                        <uri>model://meshes/drive/wheel_swivel/right_swerve_wheel_right.stl</uri>
                    </mesh>
                </geometry>
                <material>
                    <ambient>1.0 0.0 0.0 1</ambient>
                    <diffuse>1.0 0.0 0.0 1</diffuse>
                    <specular>0.1 0.1 0.1 1</specular>
                </material>
            </visual>

            <collision name="collision">
                <pose>0.292 .344 -0.25 -1.5707 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.11</radius>
                        <length>0.2</length>
                    </cylinder>
                </geometry>
            </collision>
            <visual name = "collision_visual">
                <pose>0.292 .344 -0.25 -1.5707 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.11</radius>
                        <length>0.2</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.0 1.0 0.0 0.6</ambient>
                    <diffuse>0.0 1.0 0.0 0.6</diffuse>
                    <specular>0.1 0.1 0.1 0.6</specular>
                </material>
            </visual>
        </link>

        <!-- ______ -->
        <!-- Joints -->
        <!-- ______ -->
        <joint name = "left_wheel_swivel_to_chasis" type="revolute">
            <pose>0.292 -0.574 -0.165 0 0 0</pose> 
            <parent>chasis</parent>
            <child>left_wheel_swivel</child>
            <axis>
                <xyz expressed_in="__model__">0 0 1</xyz>
                <limit>
                    <lower>-1e9</lower>
                    <upper>1e9</upper>
                </limit>
                <dynamics>
                    <damping>0.5</damping>
                    <friction>0.1</friction>
                </dynamics>
            </axis>
        </joint>
        <joint name = "right_wheel_swivel_to_chasis" type="revolute">
            <pose>0.292 0.343 -0.211 0 0 0</pose> 
            <parent>chasis</parent>
            <child>right_wheel_swivel</child>
            <axis>
                <xyz expressed_in="__model__">0 0 1</xyz>
                <limit>
                    <lower>-1e9</lower>
                    <upper>1e9</upper>
                </limit>
                <dynamics>
                    <damping>0.5</damping>
                    <friction>0.1</friction>
                </dynamics>
            </axis>
        </joint>

        <!-- ______ -->
        <!-- plugins -->
        <!-- ______ -->
        <plugin filename="gz-sim-joint-controller-system"
        name="gz::sim::systems::JointController">
            <joint_name>left_wheel_swivel_to_chasis</joint_name>
            <initial_velocity>1.0</initial_velocity>
        </plugin>
        <plugin filename="gz-sim-joint-controller-system"
        name="gz::sim::systems::JointController">
            <joint_name>right_wheel_swivel_to_chasis</joint_name>
            <initial_velocity>1.0</initial_velocity>
        </plugin>
    </model>
</sdf>