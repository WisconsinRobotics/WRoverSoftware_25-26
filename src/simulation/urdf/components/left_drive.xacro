<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name = "left_drive">
        <!-- Imports -->
         <!-- I dont understand why but ROS1 imports only work for imports T_T -->
        <xacro:include filename="$(find simulation)/urdf/util/materials.xacro"/>

        <xacro:property name = "wheel_col_radius" value = "0.11"/>
        <xacro:property name = "wheel_col_len" value = "0.2"/>


        <!-- =====================-->
        <!--     RIGHT CHASIS     -->
        <!-- =====================-->
        <xacro:property name="lc_pos_x" value = "0.292"/>
        <xacro:property name="lc_pos_y" value = "-0.115"/>
        <xacro:property name="lc_pos_z" value = "-0.0125"/>

        <xacro:property name="lc_col_x" value = "0.044"/>
        <xacro:property name="lc_col_y" value = "1.1"/>
        <xacro:property name="lc_col_z" value = "0.25"/>

        <link name = "left_chasis">
            <!-- Inertial Values-->
            <inertial>
                <mass value="6.019"/>
                <origin xyz = "${lc_pos_x} ${lc_pos_y} ${lc_pos_z}"/>
                <inertia
                    ixx="0.919"
                    ixy="-0.00008998"
                    ixz="0.000008095"
                    iyy="0.024"
                    iyz="-0.00001027"
                    izz="0.898"/>
            </inertial>

            <!-- Visuals -->
            <visual name = "ld_chasis_visual">
                <geometry>
                    <!-- And ros2 imports only work for meshes T_T -->
                    <mesh filename = "package://simulation/meshes/rd_chasis.stl"/>
                </geometry>
                <xacro:body_mat link_name = "ld_chasis"/>
            </visual>

            <!-- Collisions-->
            <collision name = "ld_chasis_collision">
                <geometry>
                    <box size="${lc_col_x} ${lc_col_y} ${lc_col_z}"/>
                </geometry>
                <origin xyz="${lc_pos_x} ${lc_pos_y} ${lc_pos_z}" rpy="0 0 0"/>
            </collision>
        </link>

        <!-- =====================-->
        <!--     BACK SWIVEL      -->
        <!-- =====================-->
        <xacro:property name="left_bs_pos_x" value = "0.292"/>
        <xacro:property name="left_bs_pos_y" value = "0.343"/>
        <xacro:property name="left_bs_pos_z" value = "-0.211"/>

        <link name = "ld_back_swivel">
            <inertial>
                <mass value="0.227"/>
                <!-- -->
                <origin xyz = "0 0 0"/>
                <inertia
                    ixx="8.402e-5"
                    ixy="4.130e-6"
                    ixz="2.454e-10"
                    iyy="7.958e-5"
                    iyz="-1.171e-11"
                    izz="1.523e-4"/>
            </inertial>

            <!-- Visuals -->
            <visual name = "ld_back_swivel_visual">
                <origin xyz="${-left_bs_pos_x} ${-left_bs_pos_y} ${-left_bs_pos_z}" rpy="0 0 0"/>
                <geometry>
                    <!-- And ros2 imports only work for meshes T_T -->
                    <mesh filename = "package://simulation/meshes/rd_back_swivel.stl"/>
                </geometry>
                <xacro:body_mat link_name = "ld_back_swivel"/>
            </visual>
        </link>

        <joint name="ld_to_bw" type="continuous">
            <parent link="left_chasis"/>
            <child link="ld_back_swivel"/>
            <origin xyz="${left_bs_pos_x} ${left_bs_pos_y} ${left_bs_pos_z}" rpy="0 0 0"/>
            <axis xyz = "0 0 1"/>
        </joint>  
        



        <!-- =====================-->
        <!--     FRONT SWIVEL      -->
        <!-- =====================-->
        <xacro:property name="ld_fs_pos_x" value = "0.292"/>
        <xacro:property name="ld_fs_pos_y" value = "-0.574"/>
        <xacro:property name="ld_fs_pos_z" value = "-0.211"/>

        <link name = "ld_front_swivel">
            <inertial>
                <mass value="0.227"/>
                <!-- -->
                <origin xyz = "0 0 0"/>
                <inertia
                    ixx="8.402e-5"
                    ixy="3.706e-6"
                    ixz="2.454e-10"
                    iyy="7.958e-5"
                    iyz="-3.206e-11"
                    izz="1.523e-4"/>
            </inertial>

            <!-- Visuals -->
            <visual name = "rd_back_swivel_visual">
                <origin xyz="${-ld_fs_pos_x} ${-ld_fs_pos_y} ${-ld_fs_pos_z}" rpy="0 0 0"/>
                <geometry>
                    <!-- And ros2 imports only work for meshes T_T -->
                    <mesh filename = "package://simulation/meshes/rd_front_swivel.stl"/>
                </geometry>
                <xacro:body_mat link_name = "ld_back_swivel"/>
            </visual>
        </link>

        <joint name="rd_to_fw" type="continuous">
            <parent link="left_chasis"/>
            <child link="ld_front_swivel"/>
            <origin xyz="${ld_fs_pos_x} ${ld_fs_pos_y} ${ld_fs_pos_z}" rpy="0 0 0"/>
            <axis xyz = "0 0 1"/>
        </joint>  

        <!-- =====================-->
        <!--     FRONT WHEEL      -->
        <!-- =====================-->
        <xacro:property name="ld_fw_pos_x" value = "0.292"/>
        <xacro:property name="ld_fw_pos_y" value = "-.574"/>
        <xacro:property name="ld_fw_pos_z" value = "-0.25"/>

        <link name = "ld_front_wheel">
            <inertial>
                <origin xyz = "0 0 0"/>
                <mass value = "0.25"/>
                <inertia
                    ixx="0.003701"
                    ixy="0"
                    ixz="0"
                    iyy="0.003701"
                    iyz="0"
                    izz="0.005832"/>
            </inertial>

            <!-- Visuals -->
            <visual name = "ld_front_wheel_visual">
                <origin xyz="${-ld_fw_pos_x} ${-ld_fw_pos_y} ${-ld_fw_pos_z}" rpy="0 0 0"/>
                <geometry>
                    <!-- And ros2 imports only work for meshes T_T -->
                    <mesh filename = "package://simulation/meshes/rd_front_wheel.stl"/>
                </geometry>
                <xacro:body_mat link_name = "ld_back_swivel"/>
            </visual>

            <collision name = "ld_front_wheel_collision">
                <origin xyz="0 0 0" rpy = "-1.5707 0 0"/>
                <geometry>
                    <cylinder 
                        radius = "${wheel_col_radius}" 
                        length = "${wheel_col_len}"
                    />
                </geometry>
            </collision>
        </link>

        <joint name = "ld_fw_to_fs" type = "continuous">
            <parent link = "ld_front_swivel"/>
            <child link = "ld_front_wheel"/>

            <!-- I dont understand why mathematically this works T_T-->
            <origin xyz="${ld_fw_pos_x - ld_fs_pos_x} ${ld_fw_pos_y - ld_fs_pos_y} ${ld_fw_pos_z - ld_fs_pos_z}" rpy="0 0 0"/>
            <axis xyz = "0 1 0"/>
        </joint>


        <!-- =====================-->
        <!--     BACK WHEEL       -->
        <!-- =====================-->
        <xacro:property name="ld_bw_pos_x" value = "0.292"/>
        <xacro:property name="ld_bw_pos_y" value = ".344"/>
        <xacro:property name="ld_bw_pos_z" value = "-0.25"/>

        <link name = "ld_back_wheel">
            <inertial>
                <origin xyz = "0 0 0"/>
                <mass value = "0.25"/>
                <inertia
                    ixx="0.003701"
                    ixy="0"
                    ixz="0"
                    iyy="0.003701"
                    iyz="0"
                    izz="0.005832"/>
            </inertial>

            <!-- Visuals -->
            <visual name = "ld_back_wheel_visual">
                <origin xyz="${-ld_bw_pos_x} ${-ld_bw_pos_y} ${-ld_bw_pos_z}" rpy="0 0 0"/>
                <geometry>
                    <!-- And ros2 imports only work for meshes T_T -->
                    <mesh filename = "package://simulation/meshes/rd_back_wheel.stl"/>
                </geometry>
                <xacro:body_mat link_name = "ld_back_swivel"/>
            </visual>

            <collision name = "ld_back_wheel_collision">
                <origin xyz="0 0 0" rpy = "-1.5707 0 0"/>
                <geometry>
                    <cylinder 
                        radius = "${wheel_col_radius}" 
                        length = "${wheel_col_len}"
                    />
                </geometry>
            </collision>
        </link>

        <joint name = "ld_bw_to_bs" type = "continuous">
            <parent link = "ld_back_swivel"/>
            <child link = "ld_back_wheel"/>

            <!-- I dont understand why mathematically this works T_T-->
            <origin xyz="${ld_bw_pos_x - left_bs_pos_x} ${ld_bw_pos_y - left_bs_pos_y} ${ld_bw_pos_z - left_bs_pos_z}" rpy="0 0 0"/>
            <axis xyz = "0 1 0"/>
        </joint>
    </xacro:macro>
</robot>